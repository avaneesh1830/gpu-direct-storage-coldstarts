# GPU instance — uses your custom ML image + cuDF/RAPIDS on top
FROM avaneesharoor/ml-experiments:latest

WORKDIR /app

# Install cuDF for GPU-accelerated dataframe processing
RUN pip install cudf-cu12 --extra-index-url=https://pypi.nvidia.com

COPY benchmark.py generate_data.py .

ENTRYPOINT []
CMD ["python3", "benchmark.py"]
